# Public frontend domain served by the `web` container.
APP_DOMAIN=licences.example.com
# Public API domain served directly by the `server` container.
API_DOMAIN=api-licences.example.com
# Host port exposed for the frontend container.
WEB_PORT=80
# Host port exposed for the API container.
API_PORT=3000
# Browser origin for the admin app.
PUBLIC_URL=https://licences.example.com
# Public API origin used by the frontend build.
API_URL=https://api-licences.example.com
# If you expose non-standard ports, reflect them in PUBLIC_URL and API_URL.
# Set to false only for plain HTTP LAN testing.
BETTER_AUTH_SECURE_COOKIES=true

POSTGRES_DB=licences
POSTGRES_USER=licences
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://licences:change-me@postgres:5432/licences

BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_ALLOWLIST=admin@example.com
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password

# PEM values can be provided on a single line with \n escapes.
LICENSE_TOKEN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----
LICENSE_TOKEN_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----

LICENSE_OFFLINE_DAYS=7
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
