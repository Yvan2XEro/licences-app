APP_DOMAIN=licences.example.com
API_DOMAIN=api-licences.example.com
PUBLIC_URL=https://licences.example.com
ACME_EMAIL=ops@example.com
BETTER_AUTH_SECURE_COOKIES=true

POSTGRES_DB=licences
POSTGRES_USER=licences
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://licences:change-me@postgres:5432/licences

BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_ALLOWLIST=admin@example.com

# PEM values can be provided on a single line with \n escapes.
LICENSE_TOKEN_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----
LICENSE_TOKEN_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----

LICENSE_OFFLINE_DAYS=7
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
